{
  "title": "CVIS v9 AIOps",
  "uid": "cvis-v9-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1, "title": "System Health", "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "cvis_health_score", "legendFormat": "Health %" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [
            {"color": "red", "value": 0},
            {"color": "yellow", "value": 60},
            {"color": "green", "value": 85}
          ]},
          "unit": "percent", "min": 0, "max": 100
        }
      }
    },
    {
      "id": 2, "title": "Ensemble Anomaly Score", "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "cvis_anomaly_score", "legendFormat": "Ensemble" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [
            {"color": "green", "value": 0},
            {"color": "yellow", "value": 0.35},
            {"color": "red", "value": 0.6}
          ]},
          "unit": "short", "min": 0, "max": 1, "decimals": 4
        }
      }
    },
    {
      "id": 3, "title": "Critical Alerts (total)", "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "cvis_alerts_critical_total", "legendFormat": "Critical" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [
            {"color": "green", "value": 0},
            {"color": "yellow", "value": 1},
            {"color": "red", "value": 5}
          ]},
          "unit": "short"
        }
      }
    },
    {
      "id": 4, "title": "ML Training Steps", "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "cvis_ml_steps_lstm", "legendFormat": "LSTM" },
        { "expr": "cvis_ml_steps_vae",  "legendFormat": "VAE" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": {"mode": "palette-classic"} } }
    },
    {
      "id": 5, "title": "Model Fitted", "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "cvis_ml_model_fitted", "legendFormat": "IF Fitted" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "WARMING"}, "1": {"text": "FITTED"}}}],
          "thresholds": { "steps": [{"color": "yellow", "value": 0}, {"color": "green", "value": 1}]}
        }
      }
    },
    {
      "id": 6, "title": "CPU / Memory / Disk %", "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "cvis_cpu_percent",    "legendFormat": "CPU %" },
        { "expr": "cvis_memory_percent", "legendFormat": "Memory %" },
        { "expr": "cvis_disk_percent",   "legendFormat": "Disk %" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100,
          "custom": { "lineInterpolation": "smooth", "fillOpacity": 10 } }
      }
    },
    {
      "id": 7, "title": "ML Anomaly Scores", "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "cvis_ml_if_score",       "legendFormat": "Isolation Forest" },
        { "expr": "cvis_ml_vae_score",      "legendFormat": "β-VAE" },
        { "expr": "cvis_ml_lstm_score",     "legendFormat": "LSTM" },
        { "expr": "cvis_anomaly_score",     "legendFormat": "Ensemble" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "max": 1,
          "custom": { "lineInterpolation": "smooth", "fillOpacity": 5 } }
      }
    },
    {
      "id": 8, "title": "Training Loss", "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "targets": [
        { "expr": "cvis_ml_lstm_loss",      "legendFormat": "LSTM MSE" },
        { "expr": "cvis_ml_vae_recon_loss", "legendFormat": "VAE Recon" },
        { "expr": "cvis_ml_vae_kl_loss",    "legendFormat": "VAE KL" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineInterpolation": "smooth" } }
      }
    },
    {
      "id": 9, "title": "Alerts Fired", "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "targets": [
        { "expr": "increase(cvis_alerts_critical_total[5m])", "legendFormat": "Critical /5m" },
        { "expr": "increase(cvis_alerts_warning_total[5m])",  "legendFormat": "Warning /5m" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 60 },
          "color": { "mode": "palette-classic" }
        }
      }
    }
  ]
}
